# ── Sui Connection ────────────────────────────────────────────────────
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
GROUPS_PACKAGE_ID=0x...

# ── Server ────────────────────────────────────────────────────────────
# Inside the enclave the relayer listens on 4000 (VSOCK-forwarded to host)
PORT=4000
REQUEST_TTL_SECONDS=900

# ── Storage ───────────────────────────────────────────────────────────
STORAGE_TYPE=memory
MEMBERSHIP_STORE_TYPE=memory

# ── Walrus Archival ───────────────────────────────────────────────────
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_STORAGE_EPOCHS=5
WALRUS_SYNC_INTERVAL_SECS=3600
WALRUS_SYNC_BATCH_SIZE=100
WALRUS_SYNC_MESSAGE_THRESHOLD=50

# ── Logging ───────────────────────────────────────────────────────────
RUST_LOG=messaging_relayer=info
